#!/command/with-contenv bash
# orchestrator service — ROS2 node that hosts session state, UI command
# routing, and policy-container dispatch (InferenceCommand.srv).

set -e

SERVICE_NAME="orchestrator"
ROS2_COMMAND="ros2 launch orchestrator orchestrator_bringup.launch.py"
COMMON_SCRIPT="/usr/local/lib/s6-services/ros2_service_run.sh"

if [ -f "${COMMON_SCRIPT}" ]; then
    exec /command/with-contenv env \
        SERVICE_NAME="${SERVICE_NAME}" \
        ROS2_COMMAND="${ROS2_COMMAND}" \
        bash "${COMMON_SCRIPT}"
else
    echo "Error: Common script not found at ${COMMON_SCRIPT}" >&2
    exit 1
fi
